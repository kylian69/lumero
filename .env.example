# Base de données PostgreSQL
# Dev local : lancer `docker compose -f docker-compose.dev.yml up -d` puis utiliser l'URL ci-dessous
DATABASE_URL="postgresql://lume:lume@localhost:5432/lume?schema=public"

# NextAuth - générer un secret avec: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGEME"
NEXTAUTH_URL="http://localhost:3000"
# Domaine du cookie de session, partagé avec les sous-domaines de preview pour
# que l'orchestrateur puisse vérifier l'accès (ex: .lumero.fr). Laisser vide en
# dev local (cookie host-only).
AUTH_COOKIE_DOMAIN=""

# Emails (Brevo - https://www.brevo.com). Si BREVO_API_KEY est vide,
# les envois sont silencieusement ignorés (utile en dev).
# Clé API : Brevo → SMTP & API → API Keys.
# EMAIL_FROM doit utiliser un domaine/expéditeur vérifié dans Brevo.
BREVO_API_KEY=""
EMAIL_FROM="Lumero <noreply@lumero.fr>"
EMAIL_REPLY_TO=""

# admin (admin@lumero.fr / admin1234)
# démo (demo@lumero.fr / demo1234)

# GitHub — Personal Access Token avec scope "repo" (création de repos)
GITHUB_TOKEN=""
GITHUB_ORG=""                          # Org ou user GitHub cible (ex: lumero-agency)

# Preview orchestrator — service self-hosted qui remplace Vercel.
# En dev local sans orchestrateur, laisser ces valeurs vides : les routes de
# provisioning ne tourneront simplement pas.
PREVIEW_ORCHESTRATOR_URL="http://localhost:8080"
PREVIEW_INTERNAL_API_TOKEN=""          # même valeur côté orchestrateur
PREVIEW_BASE_DOMAIN="lumero.fr"        # hostnames mintés en <slug>-<id6>-preview.lumero.fr

# Optionnel : URL publique du webhook GitHub des preview repos.
# Si défini lors du provisioning, Lume registre un webhook push sur le repo
# preview client pour que l'orchestrateur rebuilde à chaque push.
PREVIEW_WEBHOOK_URL=""                 # ex: https://preview.lumero.fr/webhook/github
PREVIEW_GITHUB_WEBHOOK_SECRET=""       # même valeur côté orchestrateur

# URL publique de l'app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Paiement Stripe ──────────────────────────────────────────────────────
# Si STRIPE_SECRET_KEY est vide, le paiement en ligne est désactivé : l'app
# retombe sur le flux manuel (demande de facture via le support). Pratique en
# dev/CI pour ne jamais être bloqué par le paiement.
# Pour tester sans risque, utilisez les clés de TEST (sk_test_… / pk_test_…)
# et les cartes de test Stripe (ex: 4242 4242 4242 4242).
STRIPE_SECRET_KEY=""                   # sk_test_… en dev, sk_live_… en prod
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # pk_test_… / pk_live_…
# Secret de signature du webhook (Stripe CLI : `stripe listen` l'affiche, ou
# Dashboard → Developers → Webhooks). Endpoint : /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""               # whsec_…
# Taux de TVA en points de base (2000 = 20 %). 0 = franchise en base de TVA
# (art. 293 B du CGI). Stripe génère les factures PDF conformes.
LUMERO_VAT_RATE_BPS="0"

# ─── Journalisation (logs) ────────────────────────────────────────────────
# Niveau minimum du logger technique (debug|info|warn|error). Par défaut :
# debug en dev, info en prod.
LOG_LEVEL=""
# Politique de rétention des journaux applicatifs (en jours). Les évènements
# INFO sont purgés après LOG_RETENTION_INFO_DAYS, les WARN/ERROR/SECURITY
# après LOG_RETENTION_AUDIT_DAYS.
LOG_RETENTION_INFO_DAYS="90"
LOG_RETENTION_AUDIT_DAYS="365"
# Secret de la tâche cron de purge des logs (en-tête x-cron-secret sur
# /api/cron/purge-logs). Doit être identique au CRON_SECRET de l'orchestrateur
# pour activer la purge automatique. Générer avec : openssl rand -hex 32
CRON_SECRET=""
