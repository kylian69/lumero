# Base de données PostgreSQL
# Dev local : lancer `docker compose -f docker-compose.dev.yml up -d` puis utiliser l'URL ci-dessous
DATABASE_URL="postgresql://lume:lume@localhost:5432/lume?schema=public"

# NextAuth - générer un secret avec: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGEME"
NEXTAUTH_URL="http://localhost:3000"

# Emails (Resend - https://resend.com). Si RESEND_API_KEY est vide,
# les envois sont silencieusement ignorés (utile en dev).
# Tant que le domaine n'est pas vérifié sur Resend, utiliser l'expéditeur
# sandbox : EMAIL_FROM="Lumero <onboarding@resend.dev>"
RESEND_API_KEY=""
EMAIL_FROM="Lumero <onboarding@resend.dev>"
EMAIL_REPLY_TO=""

# admin (admin@lumero.fr / admin1234)
# démo (demo@lumero.fr / demo1234)

# GitHub — Personal Access Token avec scope "repo" (création de repos)
GITHUB_TOKEN=""
GITHUB_ORG=""                          # Org ou user GitHub cible (ex: lumero-agency)

# Preview orchestrator — service self-hosted qui remplace Vercel.
# En dev local sans orchestrateur, laisser ces valeurs vides : les routes de
# provisioning ne tourneront simplement pas.
PREVIEW_ORCHESTRATOR_URL="http://localhost:8080"
PREVIEW_INTERNAL_API_TOKEN=""          # même valeur côté orchestrateur
PREVIEW_BASE_DOMAIN="lumero.fr"        # hostnames mintés en <slug>-<id6>-preview.lumero.fr

# Optionnel : URL publique du webhook GitHub des preview repos.
# Si défini lors du provisioning, Lume registre un webhook push sur le repo
# preview client pour que l'orchestrateur rebuilde à chaque push.
PREVIEW_WEBHOOK_URL=""                 # ex: https://preview.lumero.fr/webhook/github
PREVIEW_GITHUB_WEBHOOK_SECRET=""       # même valeur côté orchestrateur

# URL publique de l'app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
