# Base de données (SQLite par défaut pour le dev, remplacer par Postgres en prod)
DATABASE_URL="file:./dev.db"

# NextAuth - générer un secret avec: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGEME"
NEXTAUTH_URL="http://localhost:3000"

# Emails (Resend - https://resend.com). Si RESEND_API_KEY est vide,
# les envois sont silencieusement ignorés (utile en dev).
# Tant que le domaine n'est pas vérifié sur Resend, utiliser l'expéditeur
# sandbox : EMAIL_FROM="Lumero <onboarding@resend.dev>"
RESEND_API_KEY=""
EMAIL_FROM="Lumero <onboarding@resend.dev>"
EMAIL_REPLY_TO=""

# admin (admin@lumero.fr / admin1234)
# démo (demo@lumero.fr / demo1234)
