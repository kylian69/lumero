# ─────────────────────────────────────────────────────────────
# Staging environment for Lume (docker-compose.staging.yml).
# Copy to `.env` in the staging working copy on the VM (e.g.
# /opt/lumero-staging) and fill every value. Never commit the real .env.
#
# Use a SEPARATE Postgres password, NextAuth secret, webhook secret and
# Cloudflare tunnel from production. Use TEST credentials for any external
# service (Brevo sandbox, Stripe test keys, etc.) so staging can never touch
# real clients, money or mailboxes.
# ─────────────────────────────────────────────────────────────

# --- Database -------------------------------------------------
POSTGRES_USER=lume
POSTGRES_PASSWORD=CHANGEME_staging_password
POSTGRES_DB=lume
DATABASE_URL=postgresql://lume:CHANGEME_staging_password@postgres:5432/lume?schema=public

# --- NextAuth -------------------------------------------------
# Generate with: openssl rand -base64 32  (DO NOT reuse the prod secret)
NEXTAUTH_SECRET=CHANGEME
NEXTAUTH_URL=https://dev.lumero.fr
AUTH_COOKIE_DOMAIN=.dev.lumero.fr

# --- Public app URL -------------------------------------------
NEXT_PUBLIC_APP_URL=https://dev.lumero.fr

# --- Emails (Brevo) — use a sandbox/test key, not the prod one
BREVO_API_KEY=
EMAIL_FROM="Lumero Staging <noreply@dev.lumero.fr>"
EMAIL_REPLY_TO=contact@lumero.fr

# --- GitHub integration ---------------------------------------
GITHUB_TOKEN=
GITHUB_ORG=

# --- Preview orchestrator (Lume → orchestrator client) --------
# Internal URL used by the app container to reach the orchestrator.
PREVIEW_ORCHESTRATOR_URL=http://preview-orchestrator:8080
# Parent domain for preview hostnames.
PREVIEW_BASE_DOMAIN=dev.lumero.fr
# Separator before the base domain. Set to "-" on staging so preview hostnames
# stay ONE level under lumero.fr: <slug>-<id6>-preview-dev.lumero.fr. This is
# covered by the *.lumero.fr Cloudflare wildcard (route *-dev.lumero.fr to the
# orchestrator), whereas a two-level *.dev.lumero.fr wildcard is not.
PREVIEW_HOSTNAME_SEP=-
# Public URL of the orchestrator's GitHub webhook receiver (staging tunnel).
# Kept one level under lumero.fr for the same TLS reason.
PREVIEW_WEBHOOK_URL=https://preview-webhook-dev.lumero.fr/webhook/github
# Shared token between the app and the orchestrator (X-Internal-Token).
# Generate with: openssl rand -hex 32  (use a DIFFERENT value from prod)
PREVIEW_INTERNAL_API_TOKEN=CHANGEME_hex32
# HMAC secret for GitHub webhooks attached to preview repos.
# Generate with: openssl rand -hex 32  (use a DIFFERENT value from prod)
PREVIEW_GITHUB_WEBHOOK_SECRET=CHANGEME_hex32
# Docker network the orchestrator joins preview containers to. Defaults in the
# compose to lumero-staging_lume-staging; override here only if your project
# name differs.
# PREVIEW_NETWORK=lumero-staging_lume-staging

# --- Preview DNS automation (staging-specific) ----------------
# The staging tunnel can't own the *.lumero.fr wildcard (prod does), so the
# orchestrator creates a proxied CNAME per preview, one level under lumero.fr
# (covered by free Universal SSL), pointing at the staging tunnel.
# - API token: Cloudflare dashboard → My Profile → API Tokens → Create Token
#   with permission "Zone → DNS → Edit" scoped to the lumero.fr zone.
# - Zone ID: Cloudflare → lumero.fr overview → API section.
# - Tunnel ID: the UUID of your staging tunnel (the CNAME target is
#   <tunnel-id>.cfargotunnel.com). Found in Zero Trust → Networks → Tunnels.
PREVIEW_CLOUDFLARE_API_TOKEN=
PREVIEW_CLOUDFLARE_ZONE_ID=
PREVIEW_CLOUDFLARE_TUNNEL_ID=

# --- Seed admin (used by prisma/seed.ts on each staging deploy)
# Pick non-default credentials so the staging admin isn't guessable.
ADMIN_EMAIL=admin@dev.lumero.fr
ADMIN_PASSWORD=CHANGEME_staging_admin

# --- Deploy agent ---------------------------------------------
# SEPARATE HMAC secret from prod. Must match the GitHub Actions secret
# STAGING_DEPLOY_WEBHOOK_SECRET. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=CHANGEME_hex32

# --- Cloudflare Tunnel (locally-managed) ----------------------
# The staging tunnel is run from a config file (docker/cloudflared/
# config.staging.yml) instead of a dashboard token, so its ingress can include
# a catch-all rule for the dynamic preview hostnames.
#
# 1. Create the tunnel and credentials (once):
#      cloudflared tunnel login
#      cloudflared tunnel create lume-staging
#    This writes a <UUID>.json credentials file. Copy it next to this .env as
#    cloudflared-credentials.json (or set CLOUDFLARED_CREDENTIALS_FILE).
# 2. TUNNEL_ID = that tunnel's UUID. It is the SAME value as
#    PREVIEW_CLOUDFLARE_TUNNEL_ID above (reuse it).
# 3. Create DNS for the fixed hostnames pointing at the tunnel:
#      cloudflared tunnel route dns lume-staging dev.lumero.fr
#      cloudflared tunnel route dns lume-staging staging-webhook.lumero.fr
#      cloudflared tunnel route dns lume-staging preview-webhook-dev.lumero.fr
#    (Per-preview hostnames are created automatically by the orchestrator.)
TUNNEL_ID=CHANGEME_staging_tunnel_uuid
# Path on the host to the tunnel credentials JSON. Defaults to
# ./cloudflared-credentials.json in the staging working dir.
# CLOUDFLARED_CREDENTIALS_FILE=./cloudflared-credentials.json

# --- Compose project name -------------------------------------
# Keeps the staging stack isolated from prod on the same VM.
COMPOSE_PROJECT_NAME=lumero-staging

# --- Image override (optional) --------------------------------
# Defaults to ghcr.io/kylian69/lumero:staging. CI overrides per-deploy
# with the commit SHA tag.
# IMAGE=ghcr.io/kylian69/lumero:sha-xxxxxx
