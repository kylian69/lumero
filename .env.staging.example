# ─────────────────────────────────────────────────────────────
# Staging environment for Lume (docker-compose.staging.yml).
# Copy to `.env` in the staging working copy on the VM (e.g.
# /opt/lumero-staging) and fill every value. Never commit the real .env.
#
# Use a SEPARATE Postgres password, NextAuth secret, webhook secret and
# Cloudflare tunnel from production. Use TEST credentials for any external
# service (Brevo sandbox, Stripe test keys, etc.) so staging can never touch
# real clients, money or mailboxes.
# ─────────────────────────────────────────────────────────────

# --- Database -------------------------------------------------
POSTGRES_USER=lume
POSTGRES_PASSWORD=CHANGEME_staging_password
POSTGRES_DB=lume
DATABASE_URL=postgresql://lume:CHANGEME_staging_password@postgres:5432/lume?schema=public

# --- NextAuth -------------------------------------------------
# Generate with: openssl rand -base64 32  (DO NOT reuse the prod secret)
NEXTAUTH_SECRET=CHANGEME
NEXTAUTH_URL=https://dev.lumero.fr
AUTH_COOKIE_DOMAIN=.dev.lumero.fr

# --- Public app URL -------------------------------------------
NEXT_PUBLIC_APP_URL=https://dev.lumero.fr

# --- Emails (Brevo) — use a sandbox/test key, not the prod one
BREVO_API_KEY=
EMAIL_FROM="Lumero Staging <noreply@dev.lumero.fr>"
EMAIL_REPLY_TO=contact@lumero.fr

# --- GitHub integration ---------------------------------------
GITHUB_TOKEN=
GITHUB_ORG=

# --- Seed admin (used by prisma/seed.ts on each staging deploy)
# Pick non-default credentials so the staging admin isn't guessable.
ADMIN_EMAIL=admin@dev.lumero.fr
ADMIN_PASSWORD=CHANGEME_staging_admin

# --- Deploy agent ---------------------------------------------
# SEPARATE HMAC secret from prod. Must match the GitHub Actions secret
# STAGING_DEPLOY_WEBHOOK_SECRET. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=CHANGEME_hex32

# --- Cloudflare Tunnel ----------------------------------------
# A DEDICATED tunnel for staging (e.g. "Lume staging" → dev.lumero.fr).
# Token from one.dash.cloudflare.com → Networks → Tunnels.
TUNNEL_TOKEN=CHANGEME_paste_staging_tunnel_jwt

# --- Compose project name -------------------------------------
# Keeps the staging stack isolated from prod on the same VM.
COMPOSE_PROJECT_NAME=lumero-staging

# --- Image override (optional) --------------------------------
# Defaults to ghcr.io/kylian69/lumero:staging. CI overrides per-deploy
# with the commit SHA tag.
# IMAGE=ghcr.io/kylian69/lumero:sha-xxxxxx
