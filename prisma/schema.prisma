// Lumero - schéma de données
// CRM interne + portail client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Authentification / comptes
// ──────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  pendingEmail    String?
  passwordHash    String?
  name            String?
  firstName       String?
  lastName        String?
  avatarUrl       String?
  phone           String?
  role            Role      @default(CLIENT)
  emailVerified   DateTime?
  twoFactorSecret String?
  twoFactorEnabled Boolean  @default(false)
  mustChangePassword Boolean @default(false)
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  prospects       Prospect[]
  projects        Project[]
  subscriptions   Subscription[]
  tickets         SupportTicket[]       @relation("TicketAuthor")
  ticketMessages  TicketMessage[]
  customizations  CustomizationRequest[]
  customizationMessages CustomizationMessage[]
  notesAuthored   ProspectNote[]        @relation("NoteAuthor")
  clientNotes     ClientNote[]          @relation("ClientNotesOnUser")
  clientNotesAuthored ClientNote[]      @relation("ClientNoteAuthor")
  activities      ActivityLog[]
  verifications   VerificationCode[]
  invitations     Invitation[]          @relation("InvitedUser")
  invitationsSent Invitation[]          @relation("InvitationAuthor")
  passwordResetTokens PasswordResetToken[]
}

model SignupToken {
  id           String    @id @default(cuid())
  email        String
  tokenHash    String    @unique
  passwordHash String
  name         String?
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Invitation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("InvitedUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedById String?
  invitedBy   User?    @relation("InvitationAuthor", fields: [invitedById], references: [id], onDelete: SetNull)
  token       String   @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "email_change" | "2fa_setup"
  codeHash  String
  payload   String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, type])
}

// ──────────────────────────────────────────────────────────────
// Funnel commercial : prospects → clients
// ──────────────────────────────────────────────────────────────

enum ProspectStatus {
  NEW            // Nouveau prospect
  CONTACTED      // Premier contact fait
  QUALIFIED      // Besoin qualifié
  PROPOSAL_SENT  // Devis / maquette envoyé
  NEGOTIATING    // En négociation
  WON            // Converti en client
  LOST           // Perdu
  ARCHIVED       // Archivé
}

enum ProspectSource {
  QUESTIONNAIRE
  QUOTE_FORM
  CONTACT
  REFERRAL
  MANUAL
}

model Prospect {
  id              String         @id @default(cuid())
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  companyName     String
  contactName     String?
  email           String
  phone           String?

  status          ProspectStatus @default(NEW)
  source          ProspectSource @default(QUESTIONNAIRE)
  stageChangedAt  DateTime       @default(now())

  questionnaire   QuestionnaireResponse?
  quoteRequests   QuoteRequest[]
  notes           ProspectNote[]

  estimatedValue  Int?           // en centimes d'euros
  assignedToId    String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model ProspectNote {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([prospectId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    User     @relation("ClientNotesOnUser", fields: [clientId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("ClientNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// Réponse complète au questionnaire multi-étapes
model QuestionnaireResponse {
  id                String    @id @default(cuid())
  prospectId        String    @unique
  prospect          Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  metier            String?
  metierCustom      String?
  objectifs         String    // JSON array
  objectifCustom    String?
  style             String?
  inspiration       String?
  logoName          String?
  logoPreview       String?   // base64 ou URL
  couleur           String?
  fonctionnalites   String    // JSON array
  siteActuel        String?
  googleBusiness    String?
  instagram         String?
  facebook          String?
  linkedin          String?
  message           String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  REFUSED
  EXPIRED
}

model QuoteRequest {
  id          String      @id @default(cuid())
  prospectId  String?
  prospect    Prospect?   @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  planType    String?     // "START" | "STANDARD" | "PRO"
  subscription String?    // "NONE" | "LIGHT" | "COMPLETE"
  budget      Int?        // centimes
  timeline    String?
  details     String?

  status      QuoteStatus @default(PENDING)
  amount      Int?        // montant devis en centimes
  sentAt      DateTime?
  acceptedAt  DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
}

// ──────────────────────────────────────────────────────────────
// Client : projets, abonnements
// ──────────────────────────────────────────────────────────────

enum ProjectStatus {
  BRIEF         // Brief en cours
  DESIGN        // Maquette en préparation
  DEVELOPMENT   // Développement
  REVIEW        // Revue client
  LIVE          // En ligne
  PAUSED
  ARCHIVED
}

enum PlanType {
  START
  STANDARD
  PRO
}

model Project {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  slug            String        @unique
  domain          String?
  previewUrl      String?
  status          ProjectStatus @default(BRIEF)
  planType        PlanType      @default(START)
  launchedAt      DateTime?

  primaryColor    String?
  logoUrl         String?

  // GitHub
  githubRepoName      String?
  githubRepoUrl       String?
  githubDefaultBranch String   @default("main")
  githubPreviewBranch String   @default("preview")

  // Vercel
  vercelProjectId     String?

  // Delivery — previewStatus values: NONE | PROVISIONING | READY | REVIEW_SENT
  previewStatus       String   @default("NONE")
  previewPublishedAt  DateTime?

  subscriptions   Subscription[]
  customizations  CustomizationRequest[]
  tickets         SupportTicket[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
}

enum SubscriptionTier {
  NONE
  LIGHT
  COMPLETE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)

  tier           SubscriptionTier   @default(LIGHT)
  status         SubscriptionStatus @default(ACTIVE)
  monthlyAmount  Int                // centimes
  currency       String             @default("EUR")

  currentPeriodStart DateTime       @default(now())
  currentPeriodEnd   DateTime
  canceledAt     DateTime?

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

// ──────────────────────────────────────────────────────────────
// Demandes de personnalisation
// ──────────────────────────────────────────────────────────────

enum CustomizationStatus {
  SUBMITTED
  IN_REVIEW
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum CustomizationPriority {
  LOW
  NORMAL
  HIGH
}

model CustomizationRequest {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)

  title       String
  description String
  category    String?               // "contenu" | "design" | "fonctionnalite" | "seo" | "autre"
  priority    CustomizationPriority @default(NORMAL)
  status      CustomizationStatus   @default(SUBMITTED)

  messages    CustomizationMessage[]

  completedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([userId])
  @@index([status])
}

model CustomizationMessage {
  id          String               @id @default(cuid())
  requestId   String
  request     CustomizationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId    String
  author      User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  isInternal  Boolean              @default(false)
  createdAt   DateTime             @default(now())
  editedAt    DateTime?
  deletedAt   DateTime?
  deletedById String?
  attachments CustomizationAttachment[]

  @@index([requestId])
}

model CustomizationAttachment {
  id         String               @id @default(cuid())
  messageId  String
  message    CustomizationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  size       Int
  storageKey String
  createdAt  DateTime             @default(now())

  @@index([messageId])
}

// ──────────────────────────────────────────────────────────────
// Support
// ──────────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  WAITING_CLIENT
  WAITING_STAFF
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  TECHNIQUE
  FACTURATION
  CONTENU
  FONCTIONNALITE
  AUTRE
}

model SupportTicket {
  id          String         @id @default(cuid())
  number      Int?           @unique
  authorId    String
  author      User           @relation("TicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  subject     String
  category    TicketCategory @default(AUTRE)
  priority    TicketPriority @default(NORMAL)
  status      TicketStatus   @default(OPEN)

  messages    TicketMessage[]

  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([authorId])
  @@index([status])
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  isInternal  Boolean       @default(false) // note interne invisible au client
  createdAt   DateTime      @default(now())
  editedAt    DateTime?
  deletedAt   DateTime?
  deletedById String?
  attachments TicketAttachment[]

  @@index([ticketId])
}

model TicketAttachment {
  id         String        @id @default(cuid())
  messageId  String
  message    TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  size       Int
  storageKey String
  createdAt  DateTime      @default(now())

  @@index([messageId])
}

// ──────────────────────────────────────────────────────────────
// Journal d'activité
// ──────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entityType String   // "prospect" | "project" | "ticket" | "subscription"
  entityId   String
  action     String   // "created" | "status_changed" | "note_added" | ...
  metadata   String?  // JSON
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────
// Compteurs (séquences atomiques)
// ──────────────────────────────────────────────────────────────

model Counter {
  key   String @id
  value Int    @default(0)
}
