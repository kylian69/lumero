# ─────────────────────────────────────────────────────────────
# Production environment for Lume (docker-compose.prod.yml).
# Copy to `.env` on the production VM and fill every value.
# Never commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- Database -------------------------------------------------
# Used both by Postgres container and the app (host=postgres in the compose network)
POSTGRES_USER=lume
POSTGRES_PASSWORD=CHANGEME_strong_password
POSTGRES_DB=lume
DATABASE_URL=postgresql://lume:CHANGEME_strong_password@postgres:5432/lume?schema=public

# --- NextAuth -------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGEME
NEXTAUTH_URL=https://lumero.fr

# --- Public app URL (used in emails, webhook callbacks, etc.) -
NEXT_PUBLIC_APP_URL=https://lumero.fr

# --- Emails (Resend) ------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Lumero <noreply@lumero.fr>"
EMAIL_REPLY_TO=contact@lumero.fr

# --- GitHub integration (for client preview repos) ------------
GITHUB_TOKEN=
GITHUB_ORG=

# --- Vercel (legacy, to be removed after preview-orchestrator) -
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_WEBHOOK_SECRET=

# --- Deploy agent ---------------------------------------------
# Shared HMAC secret between GitHub Actions and the local webhook receiver.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=CHANGEME_hex32

# --- Preview orchestrator -------------------------------------
# Shared token used by Lume to call the orchestrator's /api endpoints.
# Generate with: openssl rand -hex 32
PREVIEW_INTERNAL_API_TOKEN=CHANGEME_hex32

# HMAC secret for GitHub webhooks attached to client preview repos.
# Generate with: openssl rand -hex 32
PREVIEW_GITHUB_WEBHOOK_SECRET=CHANGEME_hex32

# --- Cloudflare Tunnel ----------------------------------------
# Get from: one.dash.cloudflare.com → Networks → Tunnels →
#   "Lume" → Configure → Install connector → copy the token (eyJ...).
# The token already embeds tunnel ID + credentials.
TUNNEL_TOKEN=CHANGEME_paste_long_jwt_from_dashboard

# --- Image override (optional) --------------------------------
# When unset, defaults to ghcr.io/kylian69/lumero:latest.
# CI overrides this per-deploy with the commit SHA tag.
# IMAGE=ghcr.io/kylian69/lumero:sha-xxxxxx
